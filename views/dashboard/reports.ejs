<!DOCTYPE html>
<html lang="en">
<head>
<%- include('../partials/head', { pageTitle: 'Reports' }) %>
</head>
<body class="bg-light">

  <%- include('../partials/navbar') %>

  <div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h3 class="mb-0">📊 Reports & Analytics</h3>
        <small class="text-muted">A full breakdown of your spending</small>
      </div>
      <a href="/dashboard" class="btn btn-outline-secondary btn-sm">
        ← Dashboard
      </a>
    </div>

    <%- include('../partials/flash') %>

    <% if (!hasData) { %>
      <!-- Empty State -->
      <div class="card shadow-sm">
        <div class="card-body text-center py-5">
          <h5 class="text-muted">No expense data yet</h5>
          <p class="text-muted">Add some expenses to see your reports.</p>
          <a href="/expenses/add" class="btn btn-primary">Add Expense</a>
        </div>
      </div>

    <% } else { %>

      <!-- ── Top Summary Strip ─────────────────────────────── -->
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <div class="card shadow-sm border-start border-primary border-4">
            <div class="card-body">
              <p class="text-muted small mb-1">
                Total Spent — <%= monthName %> (Current Month)
              </p>
              <h4 class="fw-bold text-primary mb-0"
                  data-counter="<%= currentMonthTotal %>">
                ₹<%= currentMonthTotal.toFixed(2) %>
              </h4>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card shadow-sm border-start border-success border-4">
            <div class="card-body">
              <p class="text-muted small mb-1">All Time Total</p>
              <h4 class="fw-bold text-success mb-0"
                  data-counter="<%= allTimeTotal %>">
                ₹<%= allTimeTotal.toFixed(2) %>
              </h4>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Row 1: Monthly Bar + Daily Line ───────────────── -->
      <div class="row g-3 mb-4">

        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h6 class="text-muted mb-3">Monthly Spending (Last 6 Months)</h6>
              <canvas id="barChart" height="200"></canvas>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h6 class="text-muted mb-3">
                Daily Spending — <%= monthName %>
              </h6>
              <% const parsedChart = JSON.parse(chartData); %>
              <% if (parsedChart.daily.labels.length === 0) { %>
                <p class="text-muted text-center py-4">
                  No spending this month yet
                </p>
              <% } else { %>
                <canvas id="lineChart" height="200"></canvas>
              <% } %>
            </div>
          </div>
        </div>

      </div>

      <!-- ── Row 2: Doughnut + Horizontal Bar ──────────────── -->
      <div class="row g-3 mb-4">

        <div class="col-md-5">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h6 class="text-muted mb-3">Category Share</h6>
              <% const activeCats = categoryTotals.filter(c => parseFloat(c.total) > 0); %>
              <% if (activeCats.length === 0) { %>
                <p class="text-muted text-center py-4">No data yet</p>
              <% } else { %>
                <canvas id="doughnutChart" height="220"></canvas>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-md-7">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h6 class="text-muted mb-3">Category Comparison</h6>
              <% if (activeCats.length === 0) { %>
                <p class="text-muted text-center py-4">No data yet</p>
              <% } else { %>
                <!-- height set in px via inline style for horizontal bar -->
                <div style="height: 260px; position: relative;">
                  <canvas id="categoryBarChart"></canvas>
                </div>
              <% } %>
            </div>
          </div>
        </div>

      </div>

      <!-- ── Category Breakdown Table ───────────────────────── -->
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h6 class="text-muted mb-3">Category Breakdown — All Time</h6>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Category</th>
                  <th class="text-end">Total Spent</th>
                  <th>Share of Total</th>
                </tr>
              </thead>
              <tbody>
                <% categoryTotals.forEach((cat, i) => {
                     const amt   = parseFloat(cat.total);
                     const pct   = allTimeTotal > 0
                                     ? ((amt / allTimeTotal) * 100).toFixed(1)
                                     : 0;
                     // Colours matching the chart palette
                     const colours = [
                       '#4e79a7','#f28e2b','#e15759','#76b7b2',
                       '#59a14f','#edc948','#b07aa1','#ff9da7'
                     ];
                     const colour = colours[i % colours.length];
                %>
                  <tr>
                    <td>
                      <span class="d-inline-block me-2 rounded-circle"
                            style="width:10px;height:10px;
                                   background:<%= colour %>;"></span>
                      <%= cat.category_name %>
                    </td>
                    <td class="text-end fw-semibold">
                      <% if (amt > 0) { %>
                        <span class="text-success">₹<%= amt.toFixed(2) %></span>
                      <% } else { %>
                        <span class="text-muted">₹0.00</span>
                      <% } %>
                    </td>
                    <td style="min-width: 160px;">
                      <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height: 8px;">
                          <div class="progress-bar"
                               role="progressbar"
                               style="width: <%= pct %>%;
                                      background-color: <%= colour %>;"
                               aria-valuenow="<%= pct %>"
                               aria-valuemin="0"
                               aria-valuemax="100">
                          </div>
                        </div>
                        <small class="text-muted" style="min-width:38px;">
                          <%= pct %>%
                        </small>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    <% } %> <!-- end hasData -->

  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const chartData = <%- chartData %>;
  </script>
  <script src="/js/charts.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <%- include('../partials/footer') %>
</body>
</html>