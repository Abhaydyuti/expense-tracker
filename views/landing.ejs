<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { pageTitle: 'Track Your Expenses' }) %>
</head>
<body>

  <%- include('partials/navbar') %>

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <h1>Take Control of<br>Your Spending</h1>
      <p>
        Track every rupee, visualise your habits, and make
        smarter financial decisions — all in one place.
      </p>
      <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a href="/signup" class="btn btn-light btn-hero text-primary">
          Get Started Free
        </a>
        <a href="/login"
           class="btn btn-hero"
           style="border: 2px solid rgba(255,255,255,0.6); color:#fff;">
          Log In
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-5">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="fw-bold">Everything you need</h2>
        <p class="text-muted">Simple. Fast. Powerful.</p>
      </div>

      <div class="row g-4">

        <div class="col-md-4">
          <div class="card feature-card shadow-sm h-100">
            <div class="card-body">
              <div class="feature-icon">📊</div>
              <h5 class="fw-bold">Visual Charts</h5>
              <p class="text-muted">
                Bar, line and doughnut charts give you an instant
                picture of where your money is going each month.
              </p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card feature-card shadow-sm h-100">
            <div class="card-body">
              <div class="feature-icon">🔍</div>
              <h5 class="fw-bold">Smart Filters</h5>
              <p class="text-muted">
                Filter by category, month, year or custom date range.
                Find any expense in seconds.
              </p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card feature-card shadow-sm h-100">
            <div class="card-body">
              <div class="feature-icon">🔒</div>
              <h5 class="fw-bold">Private & Secure</h5>
              <p class="text-muted">
                Your data is yours alone. Passwords are hashed with
                bcrypt and each session is fully isolated.
              </p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card feature-card shadow-sm h-100">
            <div class="card-body">
              <div class="feature-icon">🗂️</div>
              <h5 class="fw-bold">Categories</h5>
              <p class="text-muted">
                Organise expenses into Food, Travel, Bills, Health
                and more. See totals per category at a glance.
              </p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card feature-card shadow-sm h-100">
            <div class="card-body">
              <div class="feature-icon">📅</div>
              <h5 class="fw-bold">Monthly Summary</h5>
              <p class="text-muted">
                Compare your spending across the last 6 months and
                spot trends before they become problems.
              </p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card feature-card shadow-sm h-100">
            <div class="card-body">
              <div class="feature-icon">📱</div>
              <h5 class="fw-bold">Works Everywhere</h5>
              <p class="text-muted">
                Fully responsive design — use it on your phone,
                tablet, or desktop without any compromise.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-5" style="background: #eef2ff;">
    <div class="container text-center">
      <h3 class="fw-bold mb-2">Ready to start tracking?</h3>
      <p class="text-muted mb-4">
        Create your free account in under a minute.
      </p>
      <a href="/signup" class="btn btn-primary btn-lg px-5">
        Create Free Account
      </a>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>