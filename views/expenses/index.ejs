<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { pageTitle: 'My Expenses' }) %>
</head>
<body class="bg-light">

  <%- include('../partials/navbar') %>

  <div class="container mt-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="mb-0">My Expenses</h3>
      <a href="/expenses/add" class="btn btn-primary">+ Add Expense</a>
    </div>

    <%- include('../partials/flash') %>

    <!-- ── Filter Panel ───────────────────────────────────── -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">

        <h6 class="text-muted mb-3">🔍 Filter Expenses</h6>

        <!-- Filters use GET so the URL updates — shareable/bookmarkable -->
        <form action="/expenses" method="GET">
          <div class="row g-3">

            <!-- Category -->
            <div class="col-md-3 col-sm-6">
              <label class="form-label">Category</label>
              <select class="form-select form-select-sm" name="category_id">
                <option value="">All Categories</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat.id %>"
                    <%= filters.category_id == cat.id ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <!-- Month -->
            <div class="col-md-2 col-sm-6">
              <label class="form-label">Month</label>
              <select class="form-select form-select-sm" name="month">
                <option value="">All Months</option>
                <% const months = [
                  'January','February','March','April',
                  'May','June','July','August',
                  'September','October','November','December'
                ];
                months.forEach((m, i) => { %>
                  <option value="<%= i + 1 %>"
                    <%= filters.month == (i + 1) ? 'selected' : '' %>>
                    <%= m %>
                  </option>
                <% }) %>
              </select>
            </div>

            <!-- Year -->
            <div class="col-md-2 col-sm-6">
              <label class="form-label">Year</label>
              <select class="form-select form-select-sm" name="year">
                <option value="">All Years</option>
                <% years.forEach(y => { %>
                  <option value="<%= y %>"
                    <%= filters.year == y ? 'selected' : '' %>>
                    <%= y %>
                  </option>
                <% }) %>
              </select>
            </div>

            <!-- Date From -->
            <div class="col-md-2 col-sm-6">
              <label class="form-label">From Date</label>
              <input
                type="date"
                class="form-control form-control-sm"
                name="date_from"
                value="<%= filters.date_from %>">
            </div>

            <!-- Date To -->
            <div class="col-md-2 col-sm-6">
              <label class="form-label">To Date</label>
              <input
                type="date"
                class="form-control form-control-sm"
                name="date_to"
                value="<%= filters.date_to %>">
            </div>

            <!-- Buttons -->
            <div class="col-md-1 col-sm-6 d-flex align-items-end gap-2">
              <button type="submit" class="btn btn-primary btn-sm w-100">
                Apply
              </button>
            </div>

          </div>

          <!-- Clear filters link — only show if any filter is active -->
          <% const hasFilter =
               filters.category_id || filters.month ||
               filters.year || filters.date_from || filters.date_to; %>

          <% if (hasFilter) { %>
            <div class="mt-2">
              <a href="/expenses" class="text-decoration-none small text-danger">
                ✕ Clear all filters
              </a>
            </div>
          <% } %>

        </form>
      </div>
    </div>
    <!-- ── End Filter Panel ───────────────────────────────── -->


    <!-- ── Expenses Table ────────────────────────────────── -->
    <div class="card shadow-sm">
      <div class="card-body p-0">

        <% if (expenses.length === 0) { %>
          <!-- Empty state -->
          <div class="text-center py-5">
            <p class="text-muted fs-5 mb-2">
              <% if (hasFilter) { %>
                No expenses match your filters.
              <% } else { %>
                No expenses yet.
              <% } %>
            </p>

            <% if (hasFilter) { %>
              <a href="/expenses" class="btn btn-outline-secondary btn-sm">
                Clear filters
              </a>
            <% } else { %>
              <a href="/expenses/add" class="btn btn-primary">
                Add your first expense
              </a>
            <% } %>
          </div>

        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">

              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <th>Title</th>
                  <th>Category</th>
                  <th class="text-end">Amount</th>
                  <th class="text-center">Actions</th>
                </tr>
              </thead>

              <tbody>
                <% expenses.forEach(expense => { %>
                  <tr>

                    <td class="text-muted" style="white-space: nowrap;">
                      <%= new Date(expense.expense_date).toLocaleDateString('en-IN', {
                        day:   '2-digit',
                        month: 'short',
                        year:  'numeric'
                      }) %>
                    </td>

                    <td>
                      <span class="fw-semibold"><%= expense.title %></span>
                      <% if (expense.notes) { %>
                        <br>
                        <small class="text-muted"><%= expense.notes %></small>
                      <% } %>
                    </td>

                    <td>
                      <%- include('../partials/categoryBadge', {
      categoryName: expense.category_name
    }) %>
                    </td>

                    <td class="text-end fw-semibold text-success">
                      ₹<%= parseFloat(expense.amount).toFixed(2) %>
                    </td>

                    <td class="text-center" style="white-space: nowrap;">
                      <a href="/expenses/edit/<%= expense.id %>"
                         class="btn btn-sm btn-outline-primary me-1">
                        Edit
                      </a>
                      <form action="/expenses/delete/<%= expense.id %>"
                            method="POST"
                            style="display:inline;"
                            onsubmit="return confirm('Delete this expense?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          Delete
                        </button>
                      </form>
                    </td>

                  </tr>
                <% }) %>
              </tbody>

            </table>
          </div>

          <!-- Filtered total -->
          <div class="px-3 py-2 border-top text-end">
            <span class="text-muted small me-2">
              <%= expenses.length %> expense<%= expenses.length !== 1 ? 's' : '' %>
            </span>
            <strong>
              Total: ₹<%= total.toFixed(2) %>
            </strong>
          </div>

        <% } %>

      </div>
    </div>
    <!-- ── End Expenses Table ─────────────────────────────── -->

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <%- include('../partials/footer') %>
</body>
</html>